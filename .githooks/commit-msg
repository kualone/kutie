#!/usr/bin/env python
"""Strip Cursor co-author trailers so GitHub contributors stay clean."""
import sys
from pathlib import Path

path = Path(sys.argv[1])
lines = path.read_text(encoding="utf-8").splitlines(keepends=True)
filtered = [line for line in lines if "Co-authored-by: Cursor" not in line]
path.write_text("".join(filtered), encoding="utf-8")
